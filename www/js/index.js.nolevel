                                bool = true;
                                com++;
                                
                            }
                        }
                    }
                    if (com >= 100){
                        break
                        
                    }
                }
                if (com >= 100){
                    bool = false;
                    break
                    
                }
            }
            if (temTab.length == 1 && store[i][j].num != co || com >= 100){
                return;
            }
            if(bool == true){
