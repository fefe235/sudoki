     }
     function remake (i,j,xx,yy) {
        if(store[i][j].error== false){
            var co = (store[i][j].num%9)+1;
        }else{
            return
        }
        var com = 1;
        var bool = true;
        var tem = co;
        var temTab = [1,2,3,4,5,6,7,8,9]
