            if (store[i][j].stop == true && temTab.length == 1){
        
        let blockB= new fabric.Rect({width:blockWi, height:blockHe, top:j*blockH + spaceH, left:i*blockW+ spaceW, fill:"#fff",stroke:"#000000",selectable:false});
